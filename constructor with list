class CIRCLE:
    def __init__ (self):
        x=int(input("enter radius:"))
        self.radius=x
    def display(self):
        print("area of circles:",3.14*self.radius**2)


a=int(input("enter num of circles:"))
circle=[]
for i in range(a):
    c=CIRCLE()
    circle.append(c)
    c.display()
    print("________________")
